# ============================================================
# Configuración del MCP Server y Telegram Bot
# Copia este archivo a .env y completa los valores reales
# ============================================================

# ------------------------------------------------------------
# OPCIONAL: Anthropic API Key
# Solo necesario si usas el SDK de Anthropic directamente.
# Si usas Claude Code CLI (claude -p), NO hace falta esta key.
# Para obtenerla: https://console.anthropic.com/settings/keys
# ------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------
# REQUERIDO: Telegram Bot Token
# Crea un bot hablando con @BotFather en Telegram:
#   1. Abre Telegram y busca @BotFather
#   2. Envía /newbot
#   3. Sigue las instrucciones y copia el token aquí
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------
# Modelo Claude a usar
# Opciones: claude-sonnet-4-6 | claude-opus-4-6 | claude-haiku-4-5-20251001
# claude-sonnet-4-6 es el balance ideal entre capacidad y costo
# ------------------------------------------------------------
CLAUDE_MODEL=claude-sonnet-4-6

# ------------------------------------------------------------
# Seguridad: usuarios de Telegram autorizados
# Lista de user IDs o @usernames separados por coma
# Deja vacío para permitir todos los usuarios (no recomendado en producción)
# Cómo obtener tu user ID: habla con @userinfobot en Telegram
# Ejemplo: ALLOWED_TELEGRAM_USERS=123456789,987654321,@mi_usuario
# ------------------------------------------------------------
ALLOWED_TELEGRAM_USERS=

# ------------------------------------------------------------
# Directorio donde se almacenan los archivos
# En EC2: /opt/mcp/files (default)
# En desarrollo local: ./files (se crea automáticamente)
# ------------------------------------------------------------
FILES_DIR=/opt/mcp/files

# ------------------------------------------------------------
# Configuración del servidor MCP
# HOST: 127.0.0.1 para solo acceso local (recomendado)
#       0.0.0.0 para acceso desde red (requiere firewall configurado)
# ------------------------------------------------------------
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8000

# ------------------------------------------------------------
# Límites
# ------------------------------------------------------------
MAX_FILE_SIZE_MB=10
MAX_HISTORY_MESSAGES=20
