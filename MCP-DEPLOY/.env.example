# ============================================================
# MCP Deploy Server + Telegram Bot — Configuración
# Copia este archivo a .env y completa todos los valores
# ============================================================

# ------------------------------------------------------------
# REQUERIDO: Telegram Bot Token
# Obtenlo hablando con @BotFather en Telegram:
#   1. Abre Telegram → busca @BotFather
#   2. Envía /newbot → sigue las instrucciones
#   3. Copia el token aquí
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------
# Seguridad: usuarios de Telegram autorizados para usar el bot
# Usa IDs numéricos o @usernames separados por coma.
# Cómo obtener tu ID: habla con @userinfobot en Telegram.
# Deja vacío para permitir todos (no recomendado en producción).
# Ejemplo: ALLOWED_TELEGRAM_USERS=123456789,@mi_usuario
# ------------------------------------------------------------
ALLOWED_TELEGRAM_USERS=

# ------------------------------------------------------------
# Chat IDs que recibirán notificaciones de estado de deploys.
# Puede ser un chat privado, grupo o canal.
# Ejemplo: NOTIFICATION_CHAT_IDS=123456789,-987654321
# ------------------------------------------------------------
NOTIFICATION_CHAT_IDS=

# ------------------------------------------------------------
# Claude Code CLI
# Ruta al binario de claude (instalado con npm install -g @anthropic-ai/claude-code)
# En EC2 con nvm: usar el wrapper /usr/local/bin/claude-run (lo crea el deploy.sh)
# ------------------------------------------------------------
CLAUDE_BIN=claude
MAX_HISTORY_MESSAGES=20

# ------------------------------------------------------------
# MCP Server — configuración de puertos
# MCP_SERVER_PORT: SSE endpoint para clientes Claude (8080)
# MCP_API_PORT:    API interna para el bot Telegram (8081)
# MCP_BASE_URL:    URL externa del MCP server (usado en headers SSE)
#                  En EC2: usar la IP privada desde el Bot
# ------------------------------------------------------------
MCP_SERVER_PORT=8080
MCP_API_PORT=8081
MCP_BASE_URL=http://127.0.0.1:8080

# ------------------------------------------------------------
# Bot → MCP: dirección del servidor MCP
# En producción EC2: usar la IP PRIVADA de la instancia MCP
# Ejemplo: MCP_SERVER_HOST=10.0.1.45
# ------------------------------------------------------------
MCP_SERVER_HOST=127.0.0.1

# ------------------------------------------------------------
# Ruta al script deployer.sh
#
# PREREQUISITO: las cuentas de GitHub deben estar autenticadas
# con `gh auth login` ANTES de ejecutar el deploy:
#
#   gh auth login --hostname github.com   # cuenta miatech
#   gh auth switch                        # cuenta aeromexico
#   gh auth login --hostname github.com   # cuenta aeromexico
#
# El script usa `gh auth switch` internamente para alternar
# entre cuentas — NO usa variables de entorno con tokens.
# ------------------------------------------------------------
DEPLOY_SCRIPT_PATH=/opt/mcp-deploy/scripts/deployer.sh

# ------------------------------------------------------------
# Directorio de logs
# ------------------------------------------------------------
LOGS_DIR=/opt/mcp-deploy/logs
